{
    "manifest_version": 3,
    "name": "Asistente inteligente de accesibilidad web",
    "version": "0.1",
    "description": "Prototipo para mejorar la accesibilidad en páginas web con IA",
    "permissions": [
        "activeTab",
        "scripting",
        "storage"
    ],
    "host_permissions": [
        "https://generativelanguage.googleapis.com/*",
        "<all_urls>"
    ],
    "background": {
        "service_worker": "back.js"
    },
    "action":{
        "default_popup": "popup.html"
    },
    "commands": {
        "toggle-extension": {
            "suggested_key": {
                "default": "Alt+Shift+A",
                "mac": "Command+Shift+A"
            },
            "description": "Activar o desactivar asistente."
        }
    }
}